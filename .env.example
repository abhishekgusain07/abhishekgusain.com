# ── Contact form: lead storage (Neon Postgres + Drizzle) ──────────────────────
# Create a free Postgres database at https://neon.tech and paste the pooled
# connection string here. Used by the /api/contact route and Drizzle Kit.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── Contact form: instant email notification (Resend) ─────────────────────────
# Get a free key at https://resend.com. Without it, leads are still saved to the
# DB — you just won't get the instant email ping.
RESEND_API_KEY=""

# Where lead notifications are sent. Defaults to your Gmail if unset.
LEAD_NOTIFY_EMAIL="abhishek.gusain1007fb@gmail.com"

# The "from" address Resend sends with. The default (onboarding@resend.dev)
# works immediately for testing. For production, verify your domain in Resend
# and use something like "Website Leads <leads@abhishekgusain.com>".
LEAD_NOTIFY_FROM="Website Leads <onboarding@resend.dev>"
